# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to `.env` or `.env.local` and fill in the values.
# Example:
#   cp .env.example .env.local

# ── CROO SDK KEY ────────────────────────────────────────────────────
# Your CROO Agent SDK key (croo_sk_...) from the CROO Dashboard.
# Required in LIVE mode. Omit only when running with CROO_MOCK=true.
CROO_SDK_KEY=

# ── MAESTRO SERVICE ID ──────────────────────────────────────────────
# The registered service ID for this orchestrator. Register the service
# in the CROO Dashboard, then paste its ID here.
MAESTRO_SERVICE_ID=

# ── SUB-AGENT SERVICE IDS ───────────────────────────────────────────
# The specialist agents Maestro hires on-chain. Each falls back to a
# built-in default if unset, but set them to your real service IDs.
WORKER_SERVICE_ID=svc_research_worker
LITMUS_SERVICE_ID=svc_litmus_grader
SUMMON_SERVICE_ID=svc_summon_human

# Optional high-availability backup researcher used for cascade failover
# and the cognitive-reflection retry when a draft fails the quality gate.
WORKER_FALLBACK_SERVICE_ID=svc_fallback_worker

# ── MOCK MODE (optional) ────────────────────────────────────────────
# Set to true for offline development — no USDC spent, no WebSocket opened.
# CROO_MOCK=true
