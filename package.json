{
  "name": "dorahacks-croo-maestro",
  "version": "0.2.0",
  "description": "Callable orchestrator — hires specialist agents on-chain, grades their work, delivers one vetted result",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "demo": "tsx scripts/e2e.ts",
    "e2e": "tsx scripts/e2e.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --silent --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high || true",
    "ci": "npm run audit && npm run lint && npm run typecheck && npm run test:coverage"
  },
  "keywords": [
    "croo",
    "agent",
    "a2a",
    "orchestrator",
    "multi-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@croo-network/sdk": "^0.2.1",
    "@edycutjong/croo-core": "^0.4.0",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.0.0",
    "license-checker": "^25.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "ws": "^8.20.1"
  }
}
